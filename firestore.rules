rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "herminio0987@gmail.com" && 
        request.auth.token.email_verified == true;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isManagerOf(clientData) {
      return isAuthenticated() && request.auth.uid == clientData.managerId;
    }

    function isPayerLinkedToManager(managerId) {
      return isAuthenticated() && 
             'email' in request.auth.token &&
             getUserData(managerId).payerEmail == request.auth.token.email.lower();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() || 
        resource.data.role == 'client' ||
        (resource.data.role == 'manager' && 'email' in request.auth.token && resource.data.payerEmail == request.auth.token.email.lower())
      );
      
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || 
                       isAdmin() || 
                       (isAuthenticated() && request.auth.uid == resource.data.managerId) || 
                       (isAuthenticated() && resource.data.role == 'client' && (!('managerId' in resource.data) || resource.data.managerId == null || resource.data.managerId == ""));
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.managerId);
    }

    // Deposits collection
    match /deposits/{depositId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.managerId || 
        resource.data.clientEmail == request.auth.token.email ||
        ('email' in request.auth.token && resource.data.payerEmail == request.auth.token.email.lower()) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.managerId;
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.managerId || isAdmin());
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.managerId || 
        resource.data.clientEmail == request.auth.token.email ||
        ('email' in request.auth.token && resource.data.payerEmail == request.auth.token.email.lower()) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.managerId;
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.managerId || isAdmin());
    }
  }
}
